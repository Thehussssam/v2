<style id="wp-custom-css">
/* TITRES DE SECTIONS */
.section-title {
  font-size: 28px;
  font-weight: 600;
  color: #1f4e79;
  margin-bottom: 20px;
}

/* PARAGRAPHES D’INTRODUCTION */
.section-intro {
  font-size: 16px;
  line-height: 1.6;
  color: #555;
  max-width: 800px;
  margin: auto;
  text-align: center;
  margin-bottom: 40px;
}



.wpcf7 select,
.wpcf7-form-control.wpcf7-select {
  all: revert !important;
  appearance: auto !important;
  background: white !important;
  border: 1px solid #ccc !important;
  padding: 8px !important;
  font-size: 16px !important;
  display: block !important;
  width: 100% !important;
  border-radius: 4px !important;
}

.iti {
  width: 100%;
}
.iti input.phone-field {
  padding-left: 75px !important;
  font-size: 16px;
  height: 44px;
  box-sizing: border-box;
}
@media only screen and (max-width: 480px) {
  .iti input.phone-field {
    padding-left: 70px !important;
    font-size: 15px;
    height: 42px;
  }
}
.iti {
  width: 100%;
}
.iti input.phone-field {
  padding-left: 75px !important;
  font-size: 16px;
  height: 44px;
  box-sizing: border-box;
}
@media only screen and (max-width: 480px) {
  .iti input.phone-field {
    padding-left: 70px !important;
    font-size: 15px;
    height: 42px;
  }
}
/* ====== Menu principal stylisé avec soulignement animé ====== */
#site-header .main-menu > li > a {
  position: relative;
  display: inline-block;
  font-family: 'Montserrat', sans-serif !important;
  font-size: 15px !important;
  font-weight: 600 !important;
  color: #ffffff !important;
  text-transform: uppercase !important;
  padding: 18px 22px !important;
  transition: all 0.3s ease;
  background-color: #000 !important;
}

#site-header .main-menu > li > a::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: 10px;
  width: 0;
  height: 2px;
  background-color: #f28c28;
  transition: width 0.3s ease;
}

#site-header .main-menu > li > a:hover::after {
  width: 100%;
}

/* Lien actif du menu */
#site-header .main-menu > li.current-menu-item > a,
#site-header .main-menu > li.current_page_item > a {
  color: #f28c28 !important;
}
#site-header .main-menu > li.current-menu-item > a::after,
#site-header .main-menu > li.current_page_item > a::after {
  width: 100%;
}

/* ====== Sous-menu stylisé ====== */
#site-header .sub-menu li a {
  font-family: 'Montserrat', sans-serif !important;
  font-size: 14px !important;
  color: #1a1a1a !important;
  padding: 12px 20px !important;
  border-bottom: 1px solid #ddd !important;
  background-color: #fff !important;
  transition: all 0.3s ease;
}

#site-header .sub-menu li a:hover {
  background-color: #f5f5f5 !important;
  color: #f28c28 !important;
}

/* Élément actif dans sous-menu */
#site-header .sub-menu .current-menu-item > a {
  font-weight: 600 !important;
  color: #f28c28 !important;
}

/* ====== Responsive – Menu réduit sur mobile ====== */
@media (max-width: 768px) {
  #site-header .main-menu > li > a {
    font-size: 13px !important;
    padding: 14px 14px !important;
  }
  #site-header .sub-menu li a {
    font-size: 12px !important;
    padding: 10px 16px !important;
  }
}
.page-title,
.entry-title,
.ct-page-title,
.site-page-title,
.case-page-title,
.breadcrumb-title {
  display: none !important;
}
</style>
