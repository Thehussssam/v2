  <body class="app" ng-class="">
    <!-- TODO: CREATE NonSRIPT GOOGLETAGMANAGER -->
    <!-- START_HTML_HEADER -->
    <section class="mini-header">
        <div class="container">
            {{$root.localize.webcontent.generic.header.InformationMiniHeader}}
        </div>
    </section>
    <header id="web-header" ng-if="($root.accountSetting.webStatus=='production' || $root.twsSetting.isDev) && !$root.twsSetting.isAPK">
        <div class="container">
        <div class="content">
            <div class="area-l ">
                <button type="button" class="navbar-toggle collapsed navbar-toggle-main" ng-click="$root.openSideNavMenu('mainMenuLeft')">
    				<span class="sr-only">Toggle navigation</span>
    				<span class="icon-bar"></span>
    				<span class="icon-bar"></span>
    				<span class="icon-bar"></span>
    			</button> 
                <a ng-link="['HomeWeb'+$root.twsSetting.language.substr(0,2)]" ng-if="$root.twsSetting.language!=undefined" title="{{$root.accountSetting.name}}" class="logo-brand"> 
        		    <img ng-src="//{{$root.accountSetting.cdn}}/images/logo_light.svg" alt="{{$root.accountSetting.name}}" class="img-responsive">
        		</a> 
                <nav class=" main-menu hidden-xs hidden-sm">
                    <ul class="nav navbar-nav navbar-left navbar-desktop">
                        <li ng-class="{'active': pageLoad==link.code}"  ng-repeat="btnData in $root.menuWebcontent | orderBy:'order'">
                            <a ng-link="[btnData.configuration.page+$root.twsSetting.language.substr(0,2)]" ng-if="btnData.type=='internal' && $root.twsSetting.language!=undefined && btnData.configuration.parent==undefined" title="{{btnData.name}}" ng-click="$root.closeSideNavMenu('mainMenuLeft')" class="nav-link">{{btnData.name}}</a>
                            <a ng-link="[btnData.configuration.parent+$root.twsSetting.language.substr(0,2),btnData.configuration.page]" ng-if="btnData.type=='internal' && $root.twsSetting.language!=undefined && btnData.configuration.parent!=undefined" title="{{btnData.name}}" ng-click="$root.closeSideNavMenu('mainMenuLeft')" class="nav-link">{{btnData.name}}</a>
                            <a href="{{btnData.configuration.url}}" ng-if="btnData.type=='external'" title="{{btnData.name}}" target="{{btnData.configuration.target}}" class="nav-link">{{btnData.name}}</a>
                            <div class="dropdown menu-hover"  ng-if="btnData.type=='submenu'"> 
                                    <input type="checkbox" id="dropdown-toggle-{{$index}}" aria-hidden="true" hidden>
                                    <label for="dropdown-toggle-{{$index}}" aria-haspopup="true" aria-expanded="false">{{btnData.name}} <span class="material-icons">keyboard_arrow_down</span></label>
                                    <nav class="dropdown-content" aria-label="submenu">
                                        <div>
                                            <li ng-repeat="subbtnData in btnData.configuration.submenu | orderBy:'order'">
                                                <a ng-link="[subbtnData.configuration.page+$root.twsSetting.language.substr(0,2)]" ng-if="subbtnData.type=='internal' && $root.twsSetting.language!=undefined && subbtnData.configuration.parent==undefined" title="{{subbtnData.name}}" role="menuitem">{{subbtnData.name}}</a>
                                                <a ng-link="[subbtnData.configuration.parent+$root.twsSetting.language.substr(0,2),subbtnData.configuration.page]" ng-if="subbtnData.type=='internal' && $root.twsSetting.language!=undefined && subbtnData.configuration.parent!=undefined" title="{{subbtnData.name}}" role="menuitem">{{subbtnData.name}}</a>
                                                <a href="{{subbtnData.configuration.url}}" ng-if="subbtnData.type=='external'" title="{{subbtnData.name}}" target="{{subbtnData.configuration.target}}" role="menuitem">{{subbtnData.name}}</a>
                                                <!-- Submenú 2 -->
                                                <div class="dropdown submenu-list" ng-if="subbtnData.type=='submenu'">
                                                            <input type="checkbox" id="dropdown-toggle-s-m-{{subbtnData.name}}-{{$index}}" aria-hidden="true" hidden>
                                                            <label for="dropdown-toggle-s-m-{{subbtnData.name}}-{{$index}}" aria-haspopup="true" aria-expanded="false">{{subbtnData.name}}</label>
                            
                                                            <nav class="dropdown-content-submenu" aria-label="submenu">
                                                                <li ng-repeat="subsubbtnData in subbtnData.configuration.submenu | orderBy:'order'">
                                                                    <a ng-link="[subsubbtnData.configuration.page+$root.twsSetting.language.substr(0,2)]" ng-if="subsubbtnData.type=='internal' && $root.twsSetting.language!=undefined && subsubbtnData.configuration.parent==undefined" title="{{subsubbtnData.name}}" role="menuitem">{{subsubbtnData.name}}</a>
                                                                    <a ng-link="[subsubbtnData.configuration.parent+$root.twsSetting.language.substr(0,2),subsubbtnData.configuration.page]" ng-if="subsubbtnData.type=='internal' && $root.twsSetting.language!=undefined && subsubbtnData.configuration.parent!=undefined" title="{{subsubbtnData.name}}" role="menuitem">{{subsubbtnData.name}}</a>
                                                                    <a href="{{subsubbtnData.configuration.url}}" ng-if="subsubbtnData.type=='external'" title="{{subsubbtnData.name}}" target="{{subsubbtnData.configuration.target}}" role="menuitem">{{subsubbtnData.name}}</a>
                                                                </li>
                                                            </nav>
                                                </div>
                                            </li>
                                        </div>    
                                    </nav>
                                    
                            </div>
                        </li> 
                    </ul>   
                </nav>   
                
            </div>

    		
            <div class="area-r">
                <md-menu md-offset="0 64" class="info hidden-xs">
    				<md-button aria-label="Contact" ng-click="$mdMenu.open($event)" class="btn-as-link">
                        <span>{{$root.localize.webcontent.generic.header.Myreservations}}</span>
                    </md-button>
            		<md-menu-content width="4">
                        <md-menu-item>
                            <a ng-link="['BookBookOnlineWeb'+$root.twsSetting.language.substr(0,2)]" ng-if="$root.twsSetting.language!=undefined" title="{{$root.localize.webcontent.generic.header.Newbook}}">
                                {{$root.localize.webcontent.generic.header.Newbook}}
                            </a>
                        </md-menu-item>
            			<md-menu-item>
                            <a href="https://webapps.aml.ma/AMLVoucher/sendVoucher" target="_blank" title="{{$root.accountSetting.mailSetting.main}}">
                                {{$root.localize.webcontent.generic.header.Eticket}}
                            </a>
                        </md-menu-item>
            			<md-menu-item>
                            <a href="#" ng-click="$mdMenu.close($event); $root.clientLogin.openDialog();" ng-if="$root.twsSetting.language!=undefined" title="{{$root.localize.webcontent.generic.header.Historical}}" >
                                {{$root.localize.webcontent.generic.header.Historical}}
                            </a>
                        </md-menu-item>
            		</md-menu-content>
                </md-menu> 
              	 
                <md-menu md-offset="0 64" class="info hidden-xs">
                	<md-button aria-label="Contact" ng-click="$mdMenu.open($event)" class="btn-as-link">
                        <span>{{$root.localize.webcontent.generic.header.Help}}</span>
                    </md-button>
                	<md-menu-content width="4">
                		<md-menu-item>
                            <a ng-link="['HelpWeb'+$root.twsSetting.language.substr(0,2)]" ng-if="$root.twsSetting.language!=undefined" title="{{$root.localize.webcontent.generic.header.Helpcenter}}" >
                                {{$root.localize.webcontent.generic.header.Helpcenter}}
                            </a>
                        </md-menu-item>
                        <md-menu-item>
                            <a ng-link="['ContactWeb'+$root.twsSetting.language.substr(0,2)]" ng-if="$root.twsSetting.language!=undefined" title="{{$root.localize.webcontent.generic.header.Customerservice}}" >
                                {{$root.localize.webcontent.generic.header.Customerservice}}
                            </a>
                        </md-menu-item>
                	</md-menu-content>
                </md-menu>  
                
              	 <md-menu md-offset="0 64" ng-if="$root.currencies.length>1" class="btn-as-link boxCurrency btn-dark"> 
        			<md-button aria-label="Currency menu" ng-click="$mdMenu.open($event)" class="btn-as-link">
        			     {{($root.currencies|filter:{code:$root.twsSetting.currency}:true)[0].symbol}}
        			     <i class="material-icons-outlined" class="arrow">expand_more</i>
            		</md-button> 				
            		<md-menu-content width="4" class="submenu-aux">
                		<md-menu-item ng-repeat="currency in $root.currencies" ng-if="currency.code !== $root.twsSetting.currency">
            				<md-button ng-click="$root.changeCurrency(currency.code)">
            					<div layout="row" flex>
            						<strong>{{currency.symbol}}</strong>&nbsp;&nbsp;{{currency.name}}
            					</div>
            				</md-button>
            			</md-menu-item>
            		</md-menu-content>
            	</md-menu>
            	
                <md-menu md-offset="0 64" ng-if="$root.languages.length>1" class="btn-as-link boxLanguage btn-dark">
                    <md-button aria-label="Language menu" class="btn-as-link btn-dropdown" ng-click="$mdOpenMenu($event)">
                        <img class="flag-languages" ng-src="//cdn.travelwebmanager.com/tws-engines/images/flags/{{ ($root.languages|filter:{code:$root.twsSetting.language}:true)[0].flagCode }}.png" /> 
                        <i class="material-icons-outlined" class="arrow">expand_more</i>
                    </md-button>
                    <md-menu-content width="4" >
                        <md-menu-item ng-repeat="language in $root.languages" ng-if="language.code !== $root.twsSetting.language ">
                            <md-button ng-click="$root.changeLanguage(language.code)">
                                <div layout="row" flex>
                                    <img class="flag-languages" ng-src="//cdn.travelwebmanager.com/tws-engines/images/flags/{{language.flagCode}}.png"/>&nbsp;{{language.name}}
                                </div>
                            </md-button>
                        </md-menu-item>
                    </md-menu-content>
                </md-menu>
        	
	        	<md-menu ng-if="$root.userMode==undefined" md-offset="0 64" class="item-box user as-link"> 
            		<md-button aria-label="logoutmenu" class="btn-as-link my-account" ng-click="$mdMenu.open($event)">
            		   <i class="material-icons-outlined text-white">person</i>
            		    <md-tooltip class="tooltip-default" md-direction="bottom">{{$root.localize.webcontent.generic.header.user}}</md-tooltip>
            		</md-button>
            		<md-menu-content width="4">
            		    <md-menu-item>
            		        <div class="legend">{{$root.localize.webcontent.generic.header.userlogheader}}</div>
            		    </md-menu-item>
            			<md-menu-item>
                            <a href="#" title="{{$root.localize.webcontent.generic.header.userlogin}}" ng-click="$mdMenu.close($event); $root.clientLogin.openDialog();">
                                <i class="material-icons icono text-muted">login</i> &nbsp;  {{$root.localize.webcontent.generic.header.userlogin}}
                            </a>								
						</md-menu-item>
						<md-menu-item>
                            <a ng-href="{{$root.localize.webcontent.generic.header.userlogurl}}" target="_self" title="{{$root.localize.webcontent.generic.header.userlogin}}" ng-click="$mdMenu.close($event);">
                                <i class="material-icons icono text-muted">person_add_alt</i> &nbsp;  <b>{{$root.localize.webcontent.generic.header.userlognew}}</b>
                            </a>								
                        </md-menu-item>
            		</md-menu-content>
            	</md-menu>             
            	
				<md-menu ng-if="$root.userMode=='client'" md-offset="0 64" class="item-box alt as-link">
            		<md-button aria-label="Profile menu" class="btn-as-link my-account" ng-click="$mdMenu.open($event)">
            		     <i class="material-icons-outlined text-white">person</i>
            		    <i class="material-icons-outlined expand">expand_more</i>
            		    <md-tooltip class="tooltip-default" md-direction="bottom">{{$root.localize.webcontent.generic.header.hi}} {{$root.clientData.name}}</md-tooltip>
            		</md-button>
            		<md-menu-content width="4">
            		    <md-menu-item>
            		        <div class="legend">{{$root.localize.webcontent.generic.header.userlogheader}}</div>
            		    </md-menu-item>                		    
            			<md-menu-item>
							<md-button ng-link="['ClientEngineWeb'+$root.twsSetting.language.substr(0,2),'AccountClientPage','ProfileClientPage']" ng-click="$mdMenu.close($event)"><md-icon md-font-set="material-icons text-muted">assignment_ind</md-icon>&nbsp;{{$root.localize.engines.content.client.MyData}}</md-button>
                        </md-menu-item>
            			<md-menu-item>
							<md-button ng-link="['ClientEngineWeb'+$root.twsSetting.language.substr(0,2),'AccountClientPage','BookingsClientPage']" ng-click="$mdMenu.close($event)"><md-icon md-font-set="material-icons text-muted">assignment_turned_in</md-icon>&nbsp;{{$root.localize.engines.content.client.Bookings}}</md-button>
                        </md-menu-item>
            			<md-menu-item>
							<md-button ng-link="['ClientEngineWeb'+$root.twsSetting.language.substr(0,2),'AccountClientPage','BudgetsClientPage']" ng-click="$mdMenu.close($event)"><md-icon md-font-set="material-icons text-muted">assignment</md-icon>&nbsp;{{$root.localize.engines.content.client.Budgets}}</md-button>
                        </md-menu-item>
            			<md-menu-item>
							<md-button ng-click="$root.clientLogin.logout()"><md-icon md-font-set="material-icons text-muted">exit_to_app</md-icon>&nbsp;{{$root.localize.engines.content.client.SignOut}}</md-button>
                        </md-menu-item>
            		</md-menu-content>
            	</md-menu>   

		               
        
            </div>    	     

        </div>                  	
	    </div>
	</header>	
    <md-sidenav class="md-sidenav-left sidenav-menu-mvl" md-component-id="mainMenuLeft" md-whiteframe="4">
                    <md-content layout-padding>
                        <div class="full-width">
                            <a ng-link="['HomeWeb'+$root.twsSetting.language.substr(0,2)]" ng-if="$root.twsSetting.language!=undefined" title="{{$root.accountSetting.name}}" target="_self" ng-click="$root.closeSideNavMenu('mainMenuLeft')" class="brand"> 
    				            <img ng-src="//{{$root.accountSetting.cdn}}/images/logo_light.svg" alt="{{$root.accountSetting.name}}" class="center-block img-responsive">
    			            </a>				        
				        </div>
                        	<ul class="nav navbar-nav ">
                            <li ng-class="{'active': pageLoad==link.code}"  ng-repeat="btnData in $root.menuWebcontent | orderBy:'order'">
                                <a ng-link="[btnData.configuration.page+$root.twsSetting.language.substr(0,2)]" ng-if="btnData.type=='internal' && $root.twsSetting.language!=undefined && btnData.configuration.parent==undefined" title="{{btnData.name}}" ng-click="$root.closeSideNavMenu('mainMenuLeft')" class="nav-link">{{btnData.name}}</a>
                                <a ng-link="[btnData.configuration.parent+$root.twsSetting.language.substr(0,2),btnData.configuration.page]" ng-if="btnData.type=='internal' && $root.twsSetting.language!=undefined && btnData.configuration.parent!=undefined" title="{{btnData.name}}" ng-click="$root.closeSideNavMenu('mainMenuLeft')" class="nav-link">{{btnData.name}}</a>
                                <a href="{{btnData.configuration.url}}" ng-if="btnData.type=='external'" title="{{btnData.name}}" target="{{btnData.configuration.target}}" class="nav-link">{{btnData.name}}</a>
                                <div class="dropdown submenu-list"  ng-if="btnData.type=='submenu'"> 
                                        <input type="checkbox" id="xs-dropdown-toggle-{{$index}}" aria-hidden="true" hidden>
                                        <label for="xs-dropdown-toggle-{{$index}}" aria-haspopup="true" aria-expanded="false">{{btnData.name}}</label>
                                        <nav class="dropdown-content" aria-label="submenu">
                                            <div>
                                                <li ng-repeat="subbtnData in btnData.configuration.submenu | orderBy:'order'">
                                                    <a ng-link="[subbtnData.configuration.page+$root.twsSetting.language.substr(0,2)]" ng-if="subbtnData.type=='internal' && $root.twsSetting.language!=undefined && subbtnData.configuration.parent==undefined" title="{{subbtnData.name}}" role="menuitem" ng-click="$root.closeSideNavMenu('mainMenuLeft')">{{subbtnData.name}}</a>
                                                    <a ng-link="[subbtnData.configuration.parent+$root.twsSetting.language.substr(0,2),subbtnData.configuration.page]" ng-if="subbtnData.type=='internal' && $root.twsSetting.language!=undefined && subbtnData.configuration.parent!=undefined" title="{{subbtnData.name}}" role="menuitem" ng-click="$root.closeSideNavMenu('mainMenuLeft')">{{subbtnData.name}}</a>
                                                    <a href="{{subbtnData.configuration.url}}" ng-if="subbtnData.type=='external'" title="{{subbtnData.name}}" target="{{subbtnData.configuration.target}}" role="menuitem">{{subbtnData.name}}</a>
                                                    <!-- Submenú 2 -->
                                                    <div class="dropdown submenu-list" ng-if="subbtnData.type=='submenu'"> 
                                                        <input type="checkbox" id="dropdown-toggle-s-{{subbtnData.name}}-{{$index}}" aria-hidden="true" hidden>
                                                        <label for="dropdown-toggle-s-{{subbtnData.name}}-{{$index}}" aria-haspopup="true" aria-expanded="false">{{subbtnData.name}}</label>
                                                        <nav class="dropdown-content-submenu" aria-label="submenu">
                                                            <li ng-repeat="subsubbtnData in subbtnData.configuration.submenu | orderBy:'order'">
                                                                <a ng-link="[subsubbtnData.configuration.page+$root.twsSetting.language.substr(0,2)]" ng-if="subsubbtnData.type=='internal' && $root.twsSetting.language!=undefined && subsubbtnData.configuration.parent==undefined" title="{{subsubbtnData.name}}" role="menuitem" ng-click="$root.closeSideNavMenu('mainMenuLeft')">{{subsubbtnData.name}}</a>
                                                                <a ng-link="[subsubbtnData.configuration.parent+$root.twsSetting.language.substr(0,2),subsubbtnData.configuration.page]" ng-if="subsubbtnData.type=='internal' && $root.twsSetting.language!=undefined && subsubbtnData.configuration.parent!=undefined" title="{{subsubbtnData.name}}" role="menuitem" ng-click="$root.closeSideNavMenu('mainMenuLeft')">{{subsubbtnData.name}}</a>
                                                                <a href="{{subsubbtnData.configuration.url}}" ng-if="subsubbtnData.type=='external'" title="{{subsubbtnData.name}}" target="{{subsubbtnData.configuration.target}}" role="menuitem">{{subsubbtnData.name}}</a>
                                                            </li>
                                                        </nav>
                                                    </div>
                                                </li>
                                            </div>    
                                        </nav>
                                        
                                </div>
                            </li> 
                            <li>
                                	<md-menu ng-if="$root.userMode==undefined" md-offset="0 64" class="nav-link"> 
            		<md-button aria-label="logoutmenu" class="nav-link" ng-click="$mdMenu.open($event)" style="padding: 5px 15px;    display: flex;    align-items: center;    color: var(--ct-color-cta);">   
            		<i class="material-icons-outlined text-white">person</i>
            		    <md-tooltip class="tooltip-default" md-direction="bottom">{{$root.localize.webcontent.generic.header.user}}</md-tooltip>
            		</md-button>
            		<md-menu-content width="4">
            		    <md-menu-item>
            		        <div class="legend">{{$root.localize.webcontent.generic.header.userlogheader}}</div>
            		    </md-menu-item>
            			<md-menu-item>
                            <a href="#" title="{{$root.localize.webcontent.generic.header.userlogin}}" ng-click="$mdMenu.close($event); $root.clientLogin.openDialog();">
                                <i class="material-icons icono text-muted">login</i> &nbsp;  {{$root.localize.webcontent.generic.header.userlogin}}
                            </a>								
						</md-menu-item>
						<md-menu-item>
                            <a ng-href="{{$root.localize.webcontent.generic.header.userlogurl}}" target="_self" title="{{$root.localize.webcontent.generic.header.userlogin}}" ng-click="$mdMenu.close($event);">
                                <i class="material-icons icono text-muted">person_add_alt</i> &nbsp;  <b>{{$root.localize.webcontent.generic.header.userlognew}}</b>
                            </a>								
                        </md-menu-item>
            		</md-menu-content>
            	</md-menu>             
            	
				
                            </li>
                            <li>
                                <md-menu ng-if="$root.userMode=='client'" md-offset="0 64" class="nav-link">
            		<md-button aria-label="Profile menu" class="nav-link" ng-click="$mdMenu.open($event)"  style="padding: 5px 15px;    display: flex;    align-items: center;    color: var(--ct-color-cta);">
            		     <i class="material-icons-outlined text-white">person</i>
            		    <i class="material-icons-outlined expand">expand_more</i>
            		    <md-tooltip class="tooltip-default" md-direction="bottom">{{$root.localize.webcontent.generic.header.hi}} {{$root.clientData.name}}</md-tooltip>
            		</md-button>
            		<md-menu-content width="4">
            		    <md-menu-item>
            		        <div class="legend">{{$root.localize.webcontent.generic.header.userlogheader}}</div>
            		    </md-menu-item>                		    
            			<md-menu-item>
							<md-button ng-link="['ClientEngineWeb'+$root.twsSetting.language.substr(0,2),'AccountClientPage','ProfileClientPage']" ng-click="$mdMenu.close($event)"><md-icon md-font-set="material-icons text-muted">assignment_ind</md-icon>&nbsp;{{$root.localize.engines.content.client.MyData}}</md-button>
                        </md-menu-item>
            			<md-menu-item>
							<md-button ng-link="['ClientEngineWeb'+$root.twsSetting.language.substr(0,2),'AccountClientPage','BookingsClientPage']" ng-click="$mdMenu.close($event)"><md-icon md-font-set="material-icons text-muted">assignment_turned_in</md-icon>&nbsp;{{$root.localize.engines.content.client.Bookings}}</md-button>
                        </md-menu-item>
            			<md-menu-item>
							<md-button ng-link="['ClientEngineWeb'+$root.twsSetting.language.substr(0,2),'AccountClientPage','BudgetsClientPage']" ng-click="$mdMenu.close($event)"><md-icon md-font-set="material-icons text-muted">assignment</md-icon>&nbsp;{{$root.localize.engines.content.client.Budgets}}</md-button>
                        </md-menu-item>
            			<md-menu-item>
							<md-button ng-click="$root.clientLogin.logout()"><md-icon md-font-set="material-icons text-muted">exit_to_app</md-icon>&nbsp;{{$root.localize.engines.content.client.SignOut}}</md-button>
                        </md-menu-item>
            		</md-menu-content>
            	</md-menu> 
                            </li>
                        </ul>
                    </md-content>
        </md-sidenav>
        <main class="ct-main ct-home" id="main-content">
    <!-- END_HTML_HEADER -->
    <div id="loader-container"></div>
    <div class="container" ng-class="{'full-width':$root.containerFullWidth}">
      <div class="row">
        <webtws></webtws>
        <div class="clearfix"></div>
      </div>
      <div class="clearfix"></div>
    </div>
    <div class="clearfix"></div>
    <!-- START_HTML_FOOTER -->
		</main>
    <footer class="ct-footer" id="web-footer" role="contentinfo" ng-if="($root.accountSetting.webStatus=='production' || $root.twsSetting.isDev) && !$root.twsSetting.isAPK">
    <div class="container">
        <div class="ct-footer__logo">
            <img ng-src="//{{$root.accountSetting.cdn}}/images/logo.svg" alt="{{$root.accountSetting.name}}" class="ct-footer__logo-img">
        </div>

        <div class="ct-footer__cols">
            <div class="ct-footer__col">
                <h2 class="ct-footer__heading">{{$root.localize.webcontent.generic.footer.Info}}</h2>
                <ul class="ct-footer__list">
                    <li><a ng-link="['HelpWeb'+$root.twsSetting.language.substr(0,2)]" ng-if="$root.twsSetting.language!=undefined" class="ct-footer__link">{{$root.localize.webcontent.generic.footer.Helpcenter}}</a></li>
                    <li><a ng-link="['ContactWeb'+$root.twsSetting.language.substr(0,2)]" ng-if="$root.twsSetting.language!=undefined" class="ct-footer__link">{{$root.localize.webcontent.generic.footer.Customerservice}}</a></li>
                </ul>
                <button type="button" class="ct-button ct-button--amal ct-footer__amal" ng-click="$root.openAmalAssistant()"><span>{{$root.localize.webcontent.generic.header.TalkToAmal}}</span><img ng-src="//{{$root.accountSetting.cdn}}/images/icn-btn.png" alt="Icon button"></button>
            </div>

            <div class="ct-footer__col">
                <h2 class="ct-footer__heading">{{$root.localize.webcontent.generic.footer.Books}}</h2>
                <ul class="ct-footer__list">
                    <li><a ng-link="['BookBookOnlineWeb'+$root.twsSetting.language.substr(0,2)]" ng-if="$root.twsSetting.language!=undefined" class="ct-footer__link">{{$root.localize.webcontent.generic.footer.Newbook}}</a></li>
                    <li><a href="#" ng-click="$root.clientLogin.openDialog();" class="ct-footer__link">{{$root.localize.webcontent.generic.footer.Mybooks}}</a></li>
                    <li><a href="https://webapps.aml.ma/AMLVoucher/sendVoucher" target="_blank" rel="noopener noreferrer" class="ct-footer__link">{{$root.localize.webcontent.generic.header.Eticket}}</a></li>
                    <li><a ng-link="['BookSalesPointsWeb'+$root.twsSetting.language.substr(0,2)]" ng-if="$root.twsSetting.language!=undefined" class="ct-footer__link">{{$root.localize.webcontent.home.PointsofSale}}</a></li>
                </ul>
            </div>

            <div class="ct-footer__col">
                <h2 class="ct-footer__heading">{{$root.localize.webcontent.generic.footer.Company}}</h2>
                <ul class="ct-footer__list">
                    <li><a ng-link="['AboutUsWeb'+$root.twsSetting.language.substr(0,2)]" ng-if="$root.twsSetting.language!=undefined" class="ct-footer__link">{{$root.localize.webcontent.generic.footer.Aboutus}}</a></li>
                    <li><a ng-link="['PressWeb'+$root.twsSetting.language.substr(0,2)]" ng-if="$root.twsSetting.language!=undefined" class="ct-footer__link">{{$root.localize.webcontent.generic.footer.Presscenter}}</a></li>
                    <li><a ng-link="['BrandWeb'+$root.twsSetting.language.substr(0,2)]" ng-if="$root.twsSetting.language!=undefined" class="ct-footer__link">{{$root.localize.webcontent.generic.footer.Brand}}</a></li>
                </ul>
            </div>

            <div class="ct-footer__col">
                <h2 class="ct-footer__heading">Légal</h2>
                <ul class="ct-footer__list">
                    <li><a ng-link="['GeneralConditionsWeb'+$root.twsSetting.language.substr(0,2)]" ng-if="$root.twsSetting.language!=undefined" class="ct-footer__link">{{$root.localize.webcontent.generic.footer.Generalconditions}}</a></li>
                    <li><a ng-link="['LegalNoticeWeb'+$root.twsSetting.language.substr(0,2)]" ng-if="$root.twsSetting.language!=undefined" class="ct-footer__link">{{$root.localize.webcontent.generic.footer.Legal}}</a></li>
                    <li><a ng-link="['PrivacyPolicyWeb'+$root.twsSetting.language.substr(0,2)]" ng-if="$root.twsSetting.language!=undefined" class="ct-footer__link">{{$root.localize.webcontent.generic.footer.Privacypolicy}}</a></li>
                    <li><a ng-href="{{$root.localize.webcontent.generic.footer.sitemapurl}}" target="_self" class="ct-footer__link">{{$root.localize.webcontent.generic.footer.sitemap}}</a></li>
                    <li><a ng-link="['CookiesWeb'+$root.twsSetting.language.substr(0,2)]" ng-if="$root.twsSetting.language!=undefined" class="ct-footer__link">{{$root.localize.webcontent.generic.footer.Cookiespolicy}}</a></li>
                </ul>
            </div>
        </div>

        <div class="ct-footer__band" aria-hidden="true">
            <img ng-src="//{{$root.accountSetting.cdn}}/images/zellige-band.webp" alt="" class="ct-footer__band-img">
        </div>

        <div class="ct-footer__bottom">
            <ul class="ct-social" aria-label="Suivez-nous sur les réseaux sociaux">
                <li ng-repeat="result in $root.localize.webcontent.generic.footer.social" ng-if="result.url">
                    <a ng-href="{{result.url}}" target="_blank" rel="noopener noreferrer" aria-label="{{result.name}}" class="ct-social__link">
                        <span class="fab {{result.icn}}" aria-hidden="true"></span>
                        <md-tooltip class="ct-tooltip">{{result.name}}</md-tooltip>
                    </a>
                </li>
            </ul>
            <p class="ct-footer__copy">©2026 {{$root.accountSetting.name}} - {{$root.localize.webcontent.generic.footer.AllRightsReserved}}.</p>
            <div class="ct-footer__powered">
                <img ng-src="//{{$root.accountSetting.cdn}}/images/powered-conectaturismo.png" alt="Powered by Conecta Turismo" class="ct-footer__powered-img">
            </div>
        </div>
    </div>
</footer>
    <a ng-link="['BookBookOnlineWeb'+$root.twsSetting.language.substr(0,2)]" target="_self" class="bookingfloating__button" ng-if="($root.accountSetting.webStatus=='production' || $root.twsSetting.isDev) && !$root.twsSetting.isAPK">
        <span class="material-icons-outlined icn">directions_boat</span>
        <md-tooltip class="tooltip-theme" md-direction="left">{{$root.localize.webcontent.generic.header.Newbook}}</md-tooltip>
    </a> 
        
        
    <!-- END_HTML_FOOTER -->
    <div class="cookiesMessage" ng-if="$root.twsSetting.cookies==null">
      <div class="container">
        <div class="title">{{$root.localize.engines.content.CookiesUse}}</div>
        <div class="clearfix"></div>
        <div class="text">{{$root.localize.engines.content.CokkiesMessage}} <a ng-link="['CookiesWeb'+$root.twsSetting.language.substr(0,2)]" title="Cookies" ng-if="$root.twsSetting.language!=undefined">{{$root.localize.generic.CookiesPolice}}</a></div>
        <div class="clearfix"></div>
        <md-button class="btn-sm md-raised md-primary pull-right" ng-click="$root.acceptCookies()">{{$root.localize.generic.Close}}</md-button>
        <div class="clearfix"></div>
      </div>
    </div>
    <div id="finishTWSloading" ng-class="{'show':$root.finishTWSloading}"></div>
  </body>

  </html>
